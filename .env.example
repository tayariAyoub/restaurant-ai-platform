# Copy this file to .env before running Docker Compose.
# These values are development placeholders. Replace every CHANGE_ME value.
POSTGRES_DB=restaurant_ai
POSTGRES_USER=restaurant_ai
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://restaurant_ai:CHANGE_ME_DATABASE_PASSWORD@db:5432/restaurant_ai
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DEMO_OWNER_EMAIL=owner@example.com
DEMO_OWNER_PASSWORD=CHANGE_ME_OWNER_PASSWORD
FRONTEND_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://backend:8000
