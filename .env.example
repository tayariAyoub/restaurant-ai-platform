# Copy this file to .env before running Docker Compose.
# These values are safe local demo defaults. Change them before production.
APP_ENV=development
LOG_LEVEL=INFO

# Required backend/database values.
POSTGRES_DB=restaurant_ai
POSTGRES_USER=restaurant_ai
POSTGRES_PASSWORD=restaurant_ai_demo_password
DATABASE_URL=postgresql+psycopg://restaurant_ai:restaurant_ai_demo_password@db:5432/restaurant_ai
JWT_SECRET=restaurant_ai_local_demo_secret_change_before_production
ADMIN_EMAIL=admin@restaurantai.com
ADMIN_PASSWORD=admin12345
DEMO_OWNER_EMAIL=owner@restaurantai.com
DEMO_OWNER_PASSWORD=owner12345

# Optional for local demos. Never commit a real key.
# Copy this file to .env, set OPENAI_API_KEY there, then restart the backend/container.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# URLs used by the backend CORS policy, frontend canonical URLs, and Docker proxy.
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://backend:8000

# Upload storage. Only local storage is implemented today.
STORAGE_PROVIDER=local

# Local/demo compatibility. Production must run Alembic explicitly and set this to false.
AUTO_MIGRATE_ON_STARTUP=true

# Public abuse protection.
RATE_LIMIT_CHAT_PER_MINUTE=10
RATE_LIMIT_RESERVATIONS_PER_MINUTE=5
RATE_LIMIT_ORDERS_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=10
TRUST_PROXY_HEADERS=false

# Optional additive cookie-auth support. Bearer tokens remain supported.
AUTH_COOKIE_ENABLED=false
AUTH_COOKIE_NAME=restaurant_ai_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_SECONDS=43200
