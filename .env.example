# Copy this file to .env before running Docker Compose.
# These values are safe local demo defaults. Change them before production.
POSTGRES_DB=restaurant_ai
POSTGRES_USER=restaurant_ai
POSTGRES_PASSWORD=restaurant_ai_demo_password
DATABASE_URL=postgresql+psycopg://restaurant_ai:restaurant_ai_demo_password@db:5432/restaurant_ai
JWT_SECRET=restaurant_ai_local_demo_secret_change_before_production
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ADMIN_EMAIL=admin@restaurantai.com
ADMIN_PASSWORD=admin12345
DEMO_OWNER_EMAIL=owner@restaurantai.com
DEMO_OWNER_PASSWORD=owner12345
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://backend:8000
